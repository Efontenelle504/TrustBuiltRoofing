---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/sections/Header.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import ProductShowcase from '../components/sections/ProductShowcase.astro';
import Certifications from '../components/sections/Certifications.astro';
import Financing from '../components/sections/Financing.astro';
import WhyChooseUs from '../components/sections/WhyChooseUs.astro';
import Reviews from '../components/sections/Reviews.astro';
import Promotions from '../components/sections/Promotions.astro';
import Gallery from '../components/sections/Gallery.astro';
import ContactCTA from '../components/sections/ContactCTA.astro';
import Footer from '../components/sections/Footer.astro';
---
<BaseLayout
  title="Trust Built Roofing | Free Roof Estimate"
  description="Request a free roofing estimate from Trust Built Roofing for roof repair, roof replacement, storm concerns, and leak assessments in South Louisiana and Mississippi."
>
  <Header />
  <Hero />
  <Services />
  <ProductShowcase />
  <Certifications />
  <Financing />
  <WhyChooseUs />
  <Reviews />
  <Promotions />
  <Gallery />
  <ContactCTA />
  <Footer />
</BaseLayout>

