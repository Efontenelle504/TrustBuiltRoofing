---
import data from './Services.content.json';
---
<!-- SECTION: Services | Edit content.json for copy, edit this file for layout -->
<section class="py-16 bg-white" id="services">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-3xl font-bold text-center text-[#1B2D4B] mb-12">{data.headline}</h2>
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      {data.cards.map((card) => (
        <div class="border border-gray-200 rounded-xl p-6 hover:shadow-lg transition-shadow">
          <h3 class="text-xl font-black text-[#1B2D4B] mb-3 uppercase">{card.title}</h3>
          <p class="text-gray-600 mb-5 leading-relaxed">{card.description}</p>
          <ul class="space-y-2 mb-6">
            {card.items.map((item) => (
              <li class="flex items-center gap-2 text-gray-700 text-sm">
                <span class="w-2 h-2 bg-[#B08A4E] rounded-full flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
          <a href="#contact" class="inline-block bg-[#B08A4E] text-white font-semibold px-5 py-2.5 rounded hover:bg-[#96733f] transition-colors text-sm">
            {card.cta}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>


